{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    },
    {
      "src": "dashboard/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "api/index.py"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/dashboard/assets/$1"
    },
    {
      "src": "/favicon.svg",
      "dest": "/dashboard/favicon.svg"
    },
    {
      "src": "/icons.svg",
      "dest": "/dashboard/icons.svg"
    },
    {
      "src": "/(.*)",
      "dest": "/dashboard/index.html"
    }
  ]
}
